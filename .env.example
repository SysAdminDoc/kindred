# Kindred Configuration
# Copy to .env and customize

# JWT secret - CHANGE THIS in production (auto-generated if not set)
# KINDRED_JWT_SECRET=your-secret-key-here

# JWT token expiry in hours
# KINDRED_JWT_EXPIRE_HOURS=72

# Default admin credentials
# KINDRED_ADMIN_EMAIL=admin@kindred.local
# KINDRED_ADMIN_PASSWORD=admin

# Server
# KINDRED_HOST=127.0.0.1
# KINDRED_USER_PORT=8000
# KINDRED_ADMIN_PORT=8001
# KINDRED_CORS_ORIGINS=*

# Database
# KINDRED_DB_PATH=./kindred.db

# Uploads
# KINDRED_UPLOAD_DIR=./uploads
# KINDRED_MAX_UPLOAD_MB=30

# Rate limiting
# KINDRED_RATE_LIMIT=60/minute
# KINDRED_RATE_LIMIT_AUTH=10/minute

# Photo reveal threshold
# KINDRED_PHOTO_REVEAL_THRESHOLD=60.0
