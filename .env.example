# Kindred Configuration
# Copy to .env and customize

# JWT secret - CHANGE THIS in production (auto-generated if not set)
# KINDRED_JWT_SECRET=your-secret-key-here

# JWT token expiry in hours
# KINDRED_JWT_EXPIRE_HOURS=72

# Default admin credentials
# KINDRED_ADMIN_EMAIL=admin@kindred.local
# KINDRED_ADMIN_PASSWORD=admin

# Server
# KINDRED_HOST=127.0.0.1
# KINDRED_USER_PORT=8000
# KINDRED_ADMIN_PORT=8001
# KINDRED_CORS_ORIGINS=*

# Database
# KINDRED_DB_PATH=./kindred.db

# Uploads
# KINDRED_UPLOAD_DIR=./uploads
# KINDRED_MAX_UPLOAD_MB=30

# Rate limiting
# KINDRED_RATE_LIMIT=60/minute
# KINDRED_RATE_LIMIT_AUTH=10/minute

# Photo reveal threshold
# KINDRED_PHOTO_REVEAL_THRESHOLD=60.0

# Logging
KINDRED_LOG_LEVEL=INFO
KINDRED_LOG_FORMAT=json

# Email (configure for production)
# KINDRED_SMTP_HOST=smtp.example.com
# KINDRED_SMTP_PORT=587
# KINDRED_SMTP_USER=
# KINDRED_SMTP_PASSWORD=
# KINDRED_SMTP_FROM=noreply@kindred.app

# Security
KINDRED_BCRYPT_ROUNDS=12
KINDRED_REFRESH_TOKEN_DAYS=30

# Web Push (VAPID) - generate at https://vapidkeys.com
# KINDRED_VAPID_PUBLIC_KEY=
# KINDRED_VAPID_PRIVATE_KEY=
# KINDRED_VAPID_CONTACT=mailto:admin@kindred.app

# Content Filtering
KINDRED_CONTENT_FILTER=true

# Premium features
KINDRED_PREMIUM_ENABLED=false

# Daily match suggestions count
KINDRED_DAILY_SUGGESTIONS=5

# Location matching
KINDRED_LOCATION_RADIUS_KM=100

# Stories
KINDRED_STORY_EXPIRY_HOURS=24

# Match expiry (days without messaging)
KINDRED_MATCH_EXPIRY_DAYS=7

# Database backups
KINDRED_BACKUP_DIR=./backups
KINDRED_BACKUP_KEEP_COUNT=7
KINDRED_BACKUP_INTERVAL_HOURS=24

# Internationalization
KINDRED_DEFAULT_LOCALE=en

# Blind Date (hours before photo/name reveal)
# KINDRED_BLIND_DATE_HOURS=48

# Message Cooldown (rate limit for new matches)
# KINDRED_MESSAGE_COOLDOWN_MINUTES=5
# KINDRED_MESSAGE_COOLDOWN_COUNT=10

# Undo Block (grace period in minutes)
# KINDRED_UNDO_BLOCK_MINUTES=5

# Safety Check-in (default timer in minutes)
# KINDRED_SAFETY_CHECKIN_MINUTES=60

# Database Vacuum (hours between auto-vacuum)
# KINDRED_VACUUM_INTERVAL_HOURS=168

# Webhooks
# KINDRED_WEBHOOKS_ENABLED=false

# Theme (mocha or latte)
# KINDRED_DEFAULT_THEME=mocha
